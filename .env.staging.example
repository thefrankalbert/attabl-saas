# Staging environment - copy to .env.staging and fill from your STAGING Supabase
# project (NOT production). Create a dedicated staging project in the Supabase
# dashboard (or use Supabase Branching) so migrations are validated against a
# real, throwaway copy before they ever touch production data.
#
# Only the keys needed by the migration tooling + a staging app run are listed.
# Mirror the rest from .env.example as needed.

# Public project URL + anon key (staging project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_STAGING_ANON_KEY

# Server-only service role key (staging project) - NEVER commit the real value
SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY

# Session pooler connection string (used by scripts/db-migrate.sh + supabase db push)
DATABASE_URL=postgresql://postgres.YOUR_STAGING_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
