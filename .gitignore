# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
tests/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# claude code worktrees
.claude/worktrees/
.worktrees/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example
!.env.staging.example

# vercel
.vercel

# supabase temp
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA generated files
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/swe-worker-*.js
.gstack/

# Local CI / agent output logs (repo root)
/build*.log
/build_*.log
/ci_*.log
/test_*.log

# DB migration backups (local/CI artifacts, never commit). The real .env.staging
# is already covered by the .env* rule above; .env.staging.example is un-ignored.
supabase/backups/
