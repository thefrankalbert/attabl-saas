# Secret guardrail - PUSH barrier.
# The push is when code "goes online". Scan the commits about to be pushed and
# REFUSE the push if any secret is present. Nothing is sent while a secret exists.
# Secrets belong in .env.local, never in the git history.

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "WARNING: gitleaks not installed, push secret scan skipped. Run: brew install gitleaks"
  exit 0
fi

ZERO=0000000000000000000000000000000000000000
fail=0

# git provides on stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue   # branch deletion: nothing to scan

  if [ "$remote_sha" = "$ZERO" ]; then
    RANGE="$local_sha --not --remotes"     # new branch: only its new commits
  else
    RANGE="$remote_sha..$local_sha"        # update: only the newly pushed commits
  fi

  gitleaks git --log-opts="$RANGE" --redact -v || fail=1
done

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "PUSH BLOCKED: a secret was detected in the commits to push. Nothing was sent online."
  echo "Clean the affected commit(s) before pushing (amend, or git filter-repo for older history)."
  exit 1
fi

exit 0
