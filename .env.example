# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (Billing SaaS)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIEL=price_monthly_essentiel_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_monthly_premium_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIEL_YEARLY=price_yearly_essentiel_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=price_yearly_premium_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Resend (Stock Alert Emails)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=Attabl <notifications@attabl.com>

# Cloudflare Turnstile (signup/login anti-bot - leave empty to disable in dev)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# App
NEXT_PUBLIC_APP_URL=https://attabl.com
NEXT_PUBLIC_APP_DOMAIN=attabl.com
NEXT_PUBLIC_ROOT_DOMAIN=attabl.com

# Cron (Vercel Cron / external scheduler -> POST /api/cron/reconcile-payments)
CRON_SECRET=

# Superadmin bootstrap script (scripts/create-superadmin.ts - never commit real values)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_RESTAURANT_NAME=La Grande Table
SUPERADMIN_TENANT_SLUG=la-grande-table

# Orange Money (optional webhook HMAC - header x-orange-signature)
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_ENV=dev
ORANGE_MONEY_WEBHOOK_SECRET=
