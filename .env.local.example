# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (Billing SaaS)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIEL=price_monthly_essentiel_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_monthly_premium_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIEL_YEARLY=price_yearly_essentiel_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=price_yearly_premium_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Resend (Stock Alert Emails)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=Attabl <notifications@attabl.com>

# Database (direct connection for scripts/migrations)
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.xxxxx:password@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# Sentry (Error Monitoring)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# Push Notifications (Web Push / VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=xxxxx
VAPID_PRIVATE_KEY=xxxxx
VAPID_SUBJECT=mailto:notifications@attabl.com

# Anthropic Claude API (AI features, optional)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# App
NEXT_PUBLIC_APP_URL=https://attabl.com
NEXT_PUBLIC_APP_DOMAIN=attabl.com
NEXT_PUBLIC_ROOT_DOMAIN=attabl.com

# Dev only (NEVER set in production)
ALLOW_DEV_AUTH_BYPASS=false
